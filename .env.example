# General
PROJECT_NAME=yhelper
ENVIRONMENT=development

# Postgres
POSTGRES_DB=yhelper
POSTGRES_USER=yhelper
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://yhelper:change_me@yhelper-postgres:5432/yhelper

# API
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3010
API_APY_MIN=-0.95
API_APY_MAX=3.0
API_MOMENTUM_ABS_MAX=1.0
API_MIN_TVL_USD=100000
API_MIN_POINTS=30
API_UNIVERSE_CORE_MIN_TVL_USD=1000000
API_UNIVERSE_CORE_MIN_POINTS=45
API_UNIVERSE_CORE_MAX_VAULTS=250
API_UNIVERSE_EXTENDED_MIN_TVL_USD=250000
API_UNIVERSE_EXTENDED_MIN_POINTS=20
API_UNIVERSE_EXTENDED_MAX_VAULTS=700
API_UNIVERSE_RAW_MIN_TVL_USD=0
API_UNIVERSE_RAW_MIN_POINTS=0
API_UNIVERSE_RAW_MAX_VAULTS=0
DEFI_LLAMA_PROTOCOL_URL=https://api.llama.fi/protocol/yearn-finance
DEFI_LLAMA_TIMEOUT_SEC=8
DEFI_LLAMA_CACHE_TTL_SEC=600

# Worker
WORKER_INTERVAL_SEC=300
KONG_MAX_VAULTS=120
KONG_MIN_TVL_USD=100000
KONG_PPS_LIMIT=120
KONG_PPS_LOOKBACK_DAYS=119
KONG_PPS_ANCHOR_SLACK_DAYS=3
KONG_TIMEOUT_SEC=12
KONG_SLEEP_BETWEEN_REQ_MS=10
PPS_RETENTION_DAYS=180
INGESTION_RUN_RETENTION_DAYS=30
DB_CLEANUP_ENABLED=1
DB_CLEANUP_MIN_INTERVAL_SEC=21600
ALERT_STALE_SECONDS=86400
ALERT_COOLDOWN_SECONDS=21600
ALERT_NOTIFY_ON_RECOVERY=1
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_DISCORD_WEBHOOK_URL=
RUNNING_STALE_SECONDS=1800

# Web
WEB_PORT=3010
NEXT_PUBLIC_API_BASE_URL=/api
API_INTERNAL_BASE_URL=/api

# Yearn sources (for next phases)
YDAEMON_URL=https://ydaemon.yearn.fi/vaults/detected?limit=2000
KONG_GQL_URL=https://kong.yearn.farm/api/gql
