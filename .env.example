# General
PROJECT_NAME=yhelper
ENVIRONMENT=development

# Postgres
POSTGRES_DB=yhelper
POSTGRES_USER=yhelper
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://yhelper:change_me@yhelper-postgres:5432/yhelper
WORKER_DATABASE_URL=postgresql://yhelper:change_me@127.0.0.1:5432/yhelper

# API
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3010
API_ASSETS_FEATURED_MIN_TVL_USD=1000000
DEFI_LLAMA_PROTOCOL_URL=https://api.llama.fi/protocol/yearn-finance

# Worker
WORKER_INTERVAL_SEC=900
KONG_MAX_VAULTS=120
KONG_MIN_TVL_USD=100000
KONG_PPS_LOOKBACK_DAYS=119
PPS_RETENTION_DAYS=122
INGESTION_RUN_RETENTION_DAYS=14
DB_CLEANUP_ENABLED=1
DB_CLEANUP_MIN_INTERVAL_SEC=86400
SNAPSHOT_MIN_ACTIVE_RATIO=0.9
SNAPSHOT_MIN_DROP_COUNT=25
ETH_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
GNOSIS_RPC_URL=
KATANA_RPC_URL=
SONIC_RPC_URL=
STYFI_SYNC_ENABLED=0
STYFI_CHAIN_ID=1
STYFI_RETENTION_DAYS=122
STYFI_SNAPSHOT_RETENTION_DAYS=30
STYFI_EPOCH_LOOKBACK=12
PRODUCT_ACTIVITY_RETENTION_DAYS=180
PRODUCT_ACTIVITY_BACKFILL_DAYS=35
PRODUCT_ACTIVITY_BLOCK_SPAN=50000
ALERT_STALE_SECONDS=86400
ALERT_COOLDOWN_SECONDS=21600
ALERT_NOTIFY_ON_RECOVERY=1
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
